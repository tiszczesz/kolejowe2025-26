@model User
<h1>Dodaj użytkownika</h1>
<form method="post" asp-action="AddUser">
    <div class="row m-2">
      <label asp-for="FirstName" class="col-3 text-end">Imię</label>
      <input asp-for="FirstName" class="col-6" />
      <span asp-validation-for="FirstName" class="col-3 text-danger"></span>
    </div>
    <div class="row m-2">
      <label asp-for="LastName" class="col-3 text-end">Nazwisko</label>
      <input asp-for="LastName" class="col-6" />
      <span asp-validation-for="LastName" class="col-3 text-danger"></span>
    </div>
    <div class="row m-2">
      <label asp-for="CreatingDate" class="col-3 text-end">Data utworzenia</label>
      <input type="date" asp-for="CreatingDate" class="col-6" />
      <span asp-validation-for="CreatingDate" class="col-3 text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Dodaj użytkownika</button>
</form>