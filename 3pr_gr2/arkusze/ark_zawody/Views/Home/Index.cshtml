@model ViewModel


<div id="glowny">
	<h2>Dodaj nowe zawody wędkarskie</h2>
	<form asp-action="Zgloszenie" method="post">
		<label>
			Łowisko:<br />
			@* <input asp-for="Zawody.Lowisko_id" type="number" /><br /> *@
			<select asp-for="Zawody.Lowisko_id">
				<option value="">Wybierz łowisko</option>
				@foreach (var lowisko in Model.LowiskaList)
				{
					<option value="@lowisko.Id">@lowisko.Akwen, @lowisko.Wojewodztwo</option>
				}
			</select><br />
		</label>
		<label>
			Data (rrrr-mm-dd):<br />
			<input type="date" asp-for="Zawody.Data_zawodow" /><br />
		</label>
		<label>
			Sędzia:<br />
			<input type="text" asp-for="Zawody.Sedzia" /><br />
		</label>
		<button type="reset">WYCZYŚĆ</button>
		<button type="submit">DODAJ</button>
	</form>
	<h2>Łowiska</h2>
	<ol>
		@foreach (var lowisko in Model.LowiskaList)
		{
			<li>@lowisko.Akwen, @lowisko.Wojewodztwo</li>
		}
	</ol>
</div>
